# TMDB API v4 read access token (Bearer). Get one (free) at:
#   https://www.themoviedb.org/settings/api  ->  "API Read Access Token"
TMDB_API_TOKEN=

# Postgres connection (matches docker-compose.yml)
DATABASE_URL=postgresql+psycopg://dramarec:dramarec@localhost:5433/dramarec

# Embedding vector dimension. Changing this after tables exist requires a
# migration (pgvector column dimensions are fixed at creation time).
# 768 matches bge-base-en-v1.5 (used in Phase 2).
EMBEDDING_DIM=768
